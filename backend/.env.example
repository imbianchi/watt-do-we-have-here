# --- Database ---
# Production: PostgreSQL via asyncpg.
# DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres
# Dev / tests: SQLite via aiosqlite (no setup required).
DATABASE_URL=sqlite+aiosqlite:///./energy.db

# --- Auth ---
# 32+ random bytes hex. Generate with: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# Fernet key for encrypting Shelly passwords at rest.
# Generate with: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- App ---
# Comma-separated allowed CORS origins (no trailing slash).
ALLOWED_ORIGINS=http://localhost:5173

# How often each device is polled (seconds).
POLL_INTERVAL=30

# Runtime flag — "development" runs init_db() on startup. Use "production" with alembic.
ENVIRONMENT=development

# --- Legacy single-device bootstrap (optional, currently unused in 3.x) ---
SHELLY_IP=
SHELLY_PASS=
