# Staging — copy to .env.staging on your staging host, never commit filled values.

# Use a separate Supabase project (or schema) for staging so production data is untouched.
DATABASE_URL=postgresql+asyncpg://postgres:STAGING_PASS@db.STAGING_PROJECT.supabase.co:5432/postgres

# DIFFERENT keys from production — staging tokens must not be valid in prod.
SECRET_KEY=
ENCRYPTION_KEY=

# Only allow the staging frontend origin.
ALLOWED_ORIGINS=https://watt-staging.vercel.app

# Marks the environment in /api/health and disables init_db() on startup.
ENVIRONMENT=staging

POLL_INTERVAL=30
